HOST=127.0.0.1
PORT=8787
ADMIN_TOKEN=
SIGNAL_STORAGE_BACKEND=auto
DATABASE_URL=
SIGNAL_DB_AUTO_MIGRATE=1
SIGNAL_DB_MIGRATE_RUN_LIMIT=200

TOSS_CLIENT_ID=your_toss_client_id
TOSS_CLIENT_SECRET=your_toss_client_secret
TOSS_ACCOUNT_SEQ=1
TOSS_BASE_URL=https://openapi.tossinvest.com
TOSS_LIVE_PRICES=1
TOSS_LIVE_CANDLES=1
TOSS_LIVE_ORDERBOOK=1
TOSS_LIVE_TRADES=1
TOSS_LIVE_PORTFOLIO=0
TOSS_PRICE_CACHE_SECONDS=15
TOSS_CANDLE_CACHE_SECONDS=60
TOSS_ORDERBOOK_CACHE_SECONDS=5
TOSS_TRADES_CACHE_SECONDS=5
TOSS_PORTFOLIO_CACHE_SECONDS=30
TOSS_STOCK_CACHE_SECONDS=86400
TOSS_REQUEST_TIMEOUT_SECONDS=5
TOSS_CANDLE_MAX_CANDIDATES=2
TOSS_ORDERBOOK_MAX_CANDIDATES=2
TOSS_TRADES_MAX_CANDIDATES=2
TOSS_TRADES_COUNT=30
TOSS_CANDLE_MAX_STALENESS_DAYS=7
# Optional audit. Set 50 to warn when old sample prices differ from Toss live prices by more than 50%.
# TOSS_SAMPLE_PRICE_DRIFT_WARN_PERCENT=50

# Optional. If set, the server uses this token instead of issuing a new one.
TOSS_ACCESS_TOKEN=

DART_API_KEY=your_opendart_api_key
DART_BASE_URL=https://opendart.fss.or.kr/api
DART_LIVE_DISCLOSURES=1
DART_DISCLOSURE_LOOKBACK_DAYS=7
DART_DISCLOSURE_CACHE_SECONDS=300
DART_REQUEST_TIMEOUT_SECONDS=6
DART_CORP_CODE_TIMEOUT_SECONDS=10
DART_DISCLOSURE_MAX_CANDIDATES=2

FX_LIVE_RATES=1
FX_RATE_URL=https://open.er-api.com/v6/latest/USD
FX_RATE_FALLBACK_URL=https://api.frankfurter.app/latest?from=USD&to=KRW
FX_RATE_CACHE_SECONDS=1800
FX_REQUEST_TIMEOUT_SECONDS=5
MARKET_INDEX_LIVE=1
MARKET_INDEX_PROVIDER=naver
MARKET_INDEX_NAVER_DOMESTIC_URL_TEMPLATE=https://polling.finance.naver.com/api/realtime/domestic/index/{symbol}
MARKET_INDEX_NAVER_WORLD_URL_TEMPLATE=https://polling.finance.naver.com/api/realtime/worldstock/index/{symbol}
MARKET_INDEX_KOSPI_SYMBOL=KOSPI
MARKET_INDEX_KOSDAQ_SYMBOL=KOSDAQ
MARKET_INDEX_NASDAQ_SYMBOL=.IXIC
MARKET_INDEX_CACHE_SECONDS=60
MARKET_INDEX_REQUEST_TIMEOUT_SECONDS=5

NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_NEWS_BASE_URL=https://openapi.naver.com/v1/search/news
NAVER_LIVE_NEWS=1
NAVER_NEWS_DISPLAY=5
NAVER_NEWS_CACHE_SECONDS=300
NAVER_NEWS_MAX_CANDIDATES=3
NAVER_REQUEST_TIMEOUT_SECONDS=5

GDELT_DOC_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_LIVE_NEWS=1
GDELT_NEWS_DISPLAY=5
GDELT_NEWS_TIMESPAN=1week
GDELT_NEWS_CACHE_SECONDS=300
GDELT_NEWS_MAX_CANDIDATES=1
GDELT_REQUEST_TIMEOUT_SECONDS=20
GDELT_REQUEST_SPACING_SECONDS=5.2

OPENAI_API_KEY=your_openai_api_key
